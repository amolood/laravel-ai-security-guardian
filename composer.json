{
  "name": "abdalmolood/laravel-ai-security-guardian",
  "description": "A defensive AI-powered Laravel security guardian package.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "ABDALRAHMAN MOLOOD",
      "email": "sudaneseh@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.8",
    "illuminate/console": "^10.0 || ^11.0 || ^12.0",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0",
    "nikic/php-parser": "^5.7"
  },
  "require-dev": {
    "larastan/larastan": "^3.0",
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
    "pestphp/pest": "^2.34 || ^3.0",
    "pestphp/pest-plugin-laravel": "^2.3 || ^3.0",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "Abdalmolood\\AiSecurityGuardian\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Abdalmolood\\AiSecurityGuardian\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Abdalmolood\\AiSecurityGuardian\\AiSecurityGuardianServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "pest",
    "test:coverage": "pest --coverage",
    "analyse": "phpstan analyse --memory-limit=512M",
    "lint": "phpstan analyse --memory-limit=512M",
    "check": [
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
